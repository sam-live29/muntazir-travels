e:{kind:"Name",value:"Filter"}}],directives:[],fields:[{kind:"FieldDefinition",name:{kind:"Name",value:"name"},arguments:[],type:{kind:"NonNullType",type:{kind:"NamedType",name:{kind:"Name",value:"FilterName"}}},directives:[]},{kind:"FieldDefinition",name:{kind:"Name",value:"type"},arguments:[],type:{kind:"NonNullType",type:{kind:"NamedType",name:{kind:"Name",value:"String"}}},directives:[]},{kind:"FieldDefinition",name:{kind:"Name",value:"enabled"},arguments:[],type:{kind:"NamedType",name:{kind:"Name",value:"Boolean"}},directives:[]}]},{kind:"ObjectTypeDefinition",name:{kind:"Name",value:"RangeFilter"},interfaces:[{kind:"NamedType",name:{kind:"Name",value:"Filter"}}],directives:[],fields:[{kind:"FieldDefinition",name:{kind:"Name",value:"name"},arguments:[],type:{kind:"NonNullType",type:{kind:"NamedType",name:{kind:"Name",value:"FilterName"}}},directives:[]},{kind:"FieldDefinition",name:{kind:"Name",value:"type"},arguments:[],type:{kind:"NonNullType",type:{kind:"NamedType",name:{kind:"Name",value:"String"}}},directives:[]},{kind:"FieldDefinition",name:{kind:"Name",value:"selectedMin"},arguments:[],type:{kind:"NamedType",name:{kind:"Name",value:"Float"}},directives:[]},{kind:"FieldDefinition",name:{kind:"Name",value:"selectedMax"},arguments:[],type:{kind:"NamedType",name:{kind:"Name",value:"Float"}},directives:[]},{kind:"FieldDefinition",name:{kind:"Name",value:"globalMin"},arguments:[],type:{kind:"NonNullType",type:{kind:"NamedType",name:{kind:"Name",value:"Float"}}},directives:[]},{kind:"FieldDefinition",name:{kind:"Name",value:"globalMax"},arguments:[],type:{kind:"NonNullType",type:{kind:"NamedType",name:{kind:"Name",value:"Float"}}},directives:[]}]},{kind:"ObjectTypeDefinition",name:{kind:"Name",value:"FindSimilarFilter"},interfaces:[{kind:"NamedType",name:{kind:"Name",value:"Filter"}}],directives:[],fields:[{kind:"FieldDefinition",name:{kind:"Name",value:"name"},arguments:[],type:{kind:"NonNullType",type:{kind:"NamedType",name:{kind:"Name",value:"FilterName"}}},directives:[]},{kind:"FieldDefinition",name:{kind:"Name",value:"type"},arguments:[],type:{kind:"NonNullType",type:{kind:"NamedType",name:{kind:"Name",value:"String"}}},directives:[]},{kind:"FieldDefinition",name:{kind:"Name",value:"attributes"},arguments:[],type:{kind:"NonNullType",type:{kind:"NamedType",name:{kind:"Name",value:"AudioFindSimilarAttributes"}}},directives:[]}]}],loc:{start:0,end:8375,source:{body:'\n  # Query\n  extend type Query {\n    getSearchResults(\n      # TODO: this has been updated and is now out of date with SGS which takes\n      # parameters as a "params" container\n      locale: String # TODO this is actually required and we should migrate it back to String!\n      pagination: PaginationInput!\n      filters: [Filter!] # TODO this is actually required and we should migrate it back to [Filter!]!\n      order: OrderInput!\n    ): SearchResults\n\n    Assets(\n      ids: [Int!]!\n    ): [Asset!]!\n  }\n\n  # Mutation\n  # getPurchasableAsset mutation technically does not modify any data\n  # But we need to be able to return a promise in order to continue a call-to-action workflow\n  # Remove this when removing isSearchGraphQLGatewayEnabled\n  # @see https://github.com/apollographql/react-apollo/issues/3499\n  extend type Mutation {\n    getPurchasableAsset(\n      id: Int!\n    ): SearchAsset\n  }\n\n  # SearchResults\n  type SearchResults {\n    # describes the state of the assets and search metadata returned from the query\n    assets: [Asset!]!\n    metadata: SearchMetadata!\n    # describes the structure/state of the filters for rendering the UI\n    filters: [Filter!]!\n    pagination: Pagination!\n    order: Order!\n  }\n\n  interface Asset {\n    id: Int!\n  }\n\n  # SearchAsset\n  extend type AssetMetadata @key(fields: "id") {\n    album: String,\n    audioTypeId: Int,\n    description: String,\n    releaseDate: String,\n    tempo: Int,\n    durationMilliseconds: Int,\n    moods: [String!],\n    genres: [String!],\n    subgenres: [String!],\n    isInstrumental: Boolean,\n    sourceProperties: RenditionSourceProperties,\n    renditionMetadata: RenditionMetadata,\n    renditionPreview: RenditionPreview,\n    waveformData1000: RenditionWaveform,\n    contributor: Contributor\n    artistName: String\n    partnerName: String\n    attribution: String!\n    title: String\n\n    # "license_details" and "is_licensed" will not be returned by the MDM Service\n    # We will need to move this data into the GraphQL Layer\n    # @todo: https://jira.corp.adobe.com/browse/STK-49316\n    licenseDetails: [LicenseDetail]! @deprecated(reason: "Use asset.licensingInformation.licenses instead")\n    # "license_transfers" will not be returned by the MDM Service\n    # We will need to move this data into the GraphQL Layer\n    # @todo: https://jira.corp.adobe.com/browse/STK-53113\n    licenseTransfers: [LicenseTransfer]! @deprecated(reason: "Use asset.licensingInformation.licenseTransfers instead")\n  }\n\n  # CommerceMetadata\n  type CommerceMetadata @key(fields: "id") {\n    isPurchasable: Boolean\n    defaultLicenseId: Int\n  }\n\n  type LicenseDetail @key(fields: "id") {\n    id: Int!\n    productKey: String!\n    licensePrice: String\n    facingPrice: String\n    downloaded: Boolean\n    isLicensed: Boolean\n  }\n\n  type LicenseTransfer @key(fields: "id") {\n    id: String!\n    date: String!\n    clientName: String!\n    notes: String\n  }\n\n  enum AssetAction {\n    LICENSE,\n    LICENSE_AGAIN,\n    DOWNLOAD_PREVIEW\n    RE_DOWNLOAD_FOR_FREE\n  }\n\n  enum LicensingWorkflow {\n    CORE_CHECKOUT\n    ENTERPRISE\n  }\n\n  enum LicenseAction {\n    TRANSFER\n  }\n\n  type License {\n    isLicensed: Boolean\n    licenseTypeId: Int\n  }\n\n  type LicensingInformation {\n    isAnyLicensed: Boolean\n    isAnyTransferred: Boolean\n    licenses: [License]\n    licensingWorkflow: LicensingWorkflow\n    licenseTransfers: [LicenseTransfer]\n  }\n\n  type RenditionPreview {\n    sourceProperties: RenditionSourceProperties\n    metadata: RenditionMetadata\n  }\n\n  type RenditionWaveform {\n    metadata: RenditionMetadata\n    sampleCount: Int\n  }\n\n  type RenditionMetadata {\n    size: Int\n    url: String\n    contentType: String\n  }\n\n  type RenditionSourceProperties {\n    bitRate: Int\n    bitsPerSample: Int\n    channels: Int\n    codecName: String\n    durationMilliseconds: Int\n    extension: String\n    sampleRate: Int\n    size: Int\n  }\n\n  type Asset @key(fields: "id") {\n    id: Int!\n    metadata: AssetMetadata\n    # details related to license, purchasability\n    commerceMetadata: CommerceMetadata! @deprecated(reason: "Use asset.licensingInformation instead")\n    assetActions: [AssetAction]\n    isLicensable: Boolean\n    licensingInformation: LicensingInformation\n  }\n\n  type Audio {\n    album: String,\n    description: String,\n    releaseDate: String,\n    tempo: Int,\n    durationMilliseconds: Int,\n    moods: [String!],\n    genres: [String!],\n    subgenres: [String!],\n    isInstrumental: Boolean,\n    sourceProperties: RenditionSourceProperties,\n    renditionMetadata: RenditionMetadata,\n    renditionPreview: RenditionPreview,\n    waveformData1000: RenditionWaveform,\n  }\n\n  type Contributor {\n    id: Int!\n    name: String!\n  }\n\n  type SearchMetadata {\n    numberOfResults: Int!\n    fsaHighlights: FsaHighlightObject\n  }\n\n  type FsaHighlightObject {\n    assetId: Int!\n    highlights: HighlightObject!\n  }\n\n  type HighlightObject {\n    start: Int!\n    end: Int!\n  }\n\n  # Pagination\n  type Pagination {\n    pageLimit: Int!\n    currentPage: Int!\n    totalNumberOfPages: Int!\n  }\n\n  input PaginationInput {\n    pageLimit: Int!\n    currentPage: Int!\n  }\n\n  # TODO(STK-XXXXX) this does not match Search Gateway Service\n  # "selection" is an ENUM\n  input OrderInput {\n    selection: String!\n  }\n\n  type Order {\n    selection: String!\n  }\n\n  # Audio find similar for uploaded content\n  type AudioFindSimilarAttributesUserUploaded {\n    type: String!\n    assetURL: String!\n    reuseToken: String\n    start: Int!\n    end: Int!\n  }\n\n  # Audio find similar for existing assets\n  type AudioFindSimilarAttributesExistingAsset {\n    type: String!\n    assetID: Int!\n    reuseToken: String\n    start: Int!\n    end: Int!\n  }\n\n  # all possible implementations of audio FSC\n  union AudioFindSimilarAttributes = AudioFindSimilarAttributesUserUploaded | AudioFindSimilarAttributesExistingAsset\n\n  # TODO: this is a strawman proposal: used to show how Unions can be utilized in FindSimilarFilter\n  #\n  # Image find similar, which is modeled to solve for the following URL use case:\n  # ?similar_content_id=1217083\n  # &find_similar_by=content\n  # &oa[0][asset_id]=1217083\n  # &oa[0][data][0][object_id]=3\n  # &oa[0][data][0][x]=0.27631578947368424\n  # &oa[0][data][0][y]=0.3162037037037037\n  # &oa[0][data][0][w]=0.17105263157894737\n  # &oa[0][data][0][h]=0.3578094541910331\n\n  # type ImageFindSimilarAttributes {\n  #   type: String!\n  #   assetID: Int\n  #   assetURL: String\n  #   reuseToken: String\n  #   # Optional: only needed when OA is desired\n  #   objectArrangement: FindSimilarObjectArrangement\n  # }\n\n  # type FindSimilarObjectArrangement {\n  #   subjects: [FindSimilarSubject!]!\n  # }\n\n  # type FindSimilarSubject {\n  #   assetID: Int!\n  #   objects: [FindSimilarObject!]!\n  # }\n\n  # type FindSimilarObject {\n  #   id: Int!\n  #   # Optional: only needed if a user is positioning the object\n  #   coordinates: FindSimilarObjectCoordinates\n  # }\n\n  # type FindSimilarObjectCoordinates {\n  #   x: Float!\n  #   y: Float!\n  #   width: Float!\n  #   height: Float!\n  # }\n\n  # when even more possible return types are defined, add them to this union\n  # union AllFindSimilarAttributeResults = AudioFindSimilarAttributes | ImageFindSimilarAttributes\n\n  # Filters\n  enum FilterName {\n    ASSET_TYPE\n    KEYWORDS\n    ALBUM\n    ATTRIBUTION\n    DURATION\n    TEMPO\n    VOCALS\n    PARTNERS\n    FIND_SIMILAR\n    MOODS\n    GENRES\n    ACOUSTIC\n    BACKGROUND\n    BLUES\n    BRASS\n    CLASSICAL\n    COUNTRY\n    DANCE\n    ELECTRONIC\n    FILM\n    HIP_HOP\n    JAZZ\n    LATIN\n    NOVELTY\n    OCCASION\n    POP\n    REGGAE\n    RELIGIOUS\n    RHYTHM_AND_BLUES\n    ROCK\n    WORLD\n    PARTNERS\n  }\n\n  interface Filter {\n    name: FilterName!\n    type: String!\n  }\n\n  type SelectionFilter implements Filter {\n    name: FilterName!\n    type: String!\n    selections: [String!]\n    values: [String!]\n  }\n\n  type TextInputFilter implements Filter {\n    name: FilterName!\n    type: String!\n    text: String\n  }\n\n  type BooleanFilter implements Filter {\n    name: FilterName!\n    type: String!\n    enabled: Boolean\n  }\n\n  type RangeFilter implements Filter {\n    name: FilterName!\n    type: String!\n    selectedMin: Float\n    selectedMax: Float\n    globalMin: Float!\n    globalMax: Float!\n  }\n\n  type FindSimilarFilter implements Filter {\n    name: FilterName!\n    type: String!\n    # TODO replace with AllFindSimilarAttributeResults\n    attributes: AudioFindSimilarAttributes!\n  }\n',name:"GraphQL request",locationOffset:{line:1,column:1}}}}},91031:(e,t,n)=>{"use strict";n.d(t,{aY:()=>d});var i=n(28640),a=n(69477);const r={name:i.D40,type:i.HSS,attributes:{__typename:i.ZKi,[i.iyY]:i.Qgs,[i.GR6]:null,[i.SF5]:null,[i.JcB]:null,[i.xcI]:null,[i.sAF]:null},__typename:i.th2},o={name:i.Z3T,type:i.qcG,[i.K9V]:i.WOB,[i.hGP]:i.N5C,[i.fid]:i.jS2,[i.wKF]:i.N5C,__typename:i.SjC},s={[i.fr5]:i.lOc,[i.$Ge]:i.m89},l={[i.fr5]:i.lOc,[i.$Ge]:i.m89,[i.DQK]:i.nZ},d=(e={},t=i.$Ge)=>{const{[a.wo.id]:{value:n=!1}={},[a.n6w.id]:{value:d=!1}={},[a.lTO.id]:{value:c=!1}={},[a.Zge.id]:{value:u=!1}={}}=e,m=u?s:l,p=Object.hasOwn(m,t)?m[t]:i.UFK,f=JSON.parse(JSON.stringify(p));return n&&f.getSearchResults.filters.push(r),c&&d&&f.getSearchResults.filters.push(o),f}},97243:(e,t,n)=>{"use strict";n.d(t,{BE:()=>p,D0:()=>m,Ju:()=>c,My:()=>d,WD:()=>l